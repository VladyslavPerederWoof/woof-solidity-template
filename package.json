{
    "name": "woof-solidity-template",
    "version": "0.0.1",
    "description": "Opinionated Solidity starter template with Hardhat 3, TypeScript, Ignition deployments, linting, docs, and security tooling preconfigured.",
    "license": "MIT",
    "author": "Woof Software",
    "private": true,
    "type": "module",
    "homepage": "https://github.com/<owner>/<repo>#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/<owner>/<repo>.git"
    },
    "scripts": {
        "prepare": "husky && pnpm build && pnpm gen:docs",
        "clean": "bash scripts/commands/clean.sh",
        "build": "pnpm hardhat build",
        "test": "pnpm hardhat test mocha",
        "coverage": "pnpm hardhat test mocha --coverage",
        "lint": "pnpm run lint:ts && pnpm run lint:sol",
        "lint:fix": "pnpm run lint:ts:fix && pnpm run lint:sol:fix",
        "lint:ts": "pnpm prettier --check \"**/*.{ts,js}\" && pnpm eslint .",
        "lint:ts:fix": "pnpm prettier --write \"**/*.{ts,js}\" && pnpm eslint . --fix",
        "lint:sol": "pnpm solhint \"contracts/**/*.sol\" && pnpm prettier --no-error-on-unmatched-pattern --check \"{contracts,test}/**/*.sol\"",
        "lint:sol:fix": "pnpm solhint --fix \"contracts/**/*.sol\" && pnpm prettier --no-error-on-unmatched-pattern --write \"{contracts,test}/**/*.sol\"",
        "gen:abi": "pnpm hardhat abi clean && pnpm hardhat abi export",
        "gen:security-reports": "pnpm hardhat clean && pnpm hardhat build && bash scripts/commands/aderyn.sh && bash scripts/commands/slither.sh",
        "gen:docs": "rm -rf generated-markups docs && pnpm hardhat markup --outdir docs && rm -rf docs/contracts/mocks"
    },
    "devDependencies": {
        "@commitlint/cli": "20.4.1",
        "@commitlint/config-conventional": "20.4.1",
        "@commitlint/types": "20.4.0",
        "@eslint/compat": "^1.2.8",
        "@eslint/js": "^9.25.1",
        "@nomicfoundation/hardhat-ethers": "^4.0.8",
        "@nomicfoundation/hardhat-ignition": "^3.1.2",
        "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.4",
        "@nomicfoundation/hardhat-network-helpers": "^3.0.4",
        "@solarity/hardhat-markup": "^2.0.0",
        "@solidstate/hardhat-abi-exporter": "^3.0.1",
        "@solidstate/hardhat-contract-sizer": "^3.0.0",
        "@types/chai": "^5.2.3",
        "@types/chai-as-promised": "^8.0.2",
        "@types/mocha": "^10.0.10",
        "@types/node": "^22.19.17",
        "chai": "^6.2.2",
        "eslint": "^9.25.1",
        "eslint-config-prettier": "10.1.8",
        "ethers": "^6.16.0",
        "hardhat": "^3.4.0",
        "husky": "^9.1.7",
        "mocha": "^11.7.5",
        "prettier": "3.8.1",
        "prettier-plugin-solidity": "2.2.1",
        "solhint": "6.0.3",
        "tsx": "^4.21.0",
        "typescript": "~5.8.3",
        "typescript-eslint": "8.55.0",
        "globals": "^17.4.0"
    },
    "engines": {
        "node": ">=22.10.0",
        "npm": "please-use-pnpm",
        "yarn": "please-use-pnpm"
    },
    "packageManager": "pnpm@10.29.3"
}
